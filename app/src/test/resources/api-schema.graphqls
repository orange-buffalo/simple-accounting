    currency: String! @notBlank,
    "ID of the customer for this invoice."
    customerId: Long!,
    "New date when the invoice was issued."
    dateIssued: LocalDate!,
    "New date when the invoice was paid."
    datePaid: LocalDate,
    "New date when the invoice was sent."
    dateSent: LocalDate,
    "New due date of the invoice."
    dueDate: LocalDate!,
    "New ID of the general tax applied to this invoice."
    generalTaxId: Long,
    "ID of the invoice to update."
    id: Long!,
    "New optional notes for the invoice."
    notes: String @size(max : 1024, min : 0),
    "New title of the invoice."
    title: String! @notBlank @size(max : 255, min : 0),
    "ID of the workspace the invoice belongs to."
    workspaceId: Long!
  ): Invoice! @auth(type : REGULAR_USER)
  "Updates an existing workspace."
  editWorkspace(
    "ID of the workspace to update."
    id: Long!,
    "New name of the workspace."
    name: String! @notBlank @size(max : 255, min : 0)
  ): Workspace! @auth(type : REGULAR_USER)
