"GraphQL schema for Simple Accounting application"
schema @contact(description : "For any questions, issues or feature requests, please open an issue or discussion on GitHub.", name : "Simple Accounting", url : "https://github.com/orange-buffalo/simple-accounting/issues"){
  query: Query
  mutation: Mutation
}

"Defines the authorization requirements for the request. If a request context does not satisfy the requirements, it will be rejected with an error code `NOT_AUTHORIZED`."
directive @auth(type: AuthType!) on FIELD_DEFINITION

"Declares a business error that can be returned by this operation. When the specified exception is thrown, the response will include an error with extensions.errorType = 'BUSINESS_ERROR' and extensions.errorCode containing the declared error code."
directive @businessError(errorCode: String!, errorCodeDescription: String!) repeatable on FIELD_DEFINITION

"Provides contact information of the owner responsible for this subgraph schema."
directive @contact(description: String!, name: String!, url: String!) on SCHEMA

"Marks the field, argument, input field or enum value as deprecated"
directive @deprecated(
    "The reason for the deprecation"
    reason: String! = "No longer supported"
  ) on FIELD_DEFINITION | ARGUMENT_DEFINITION | ENUM_VALUE | INPUT_FIELD_DEFINITION

"This directive disables error propagation when a non nullable field returns null for the given operation."
directive @experimental_disableErrorPropagation on QUERY | MUTATION | SUBSCRIPTION

"Directs the executor to include this field or fragment only when the `if` argument is true"
directive @include(
    "Included when true."
    if: Boolean!
  ) on FIELD | FRAGMENT_SPREAD | INLINE_FRAGMENT

"Validates that the value is at most the specified maximum"
directive @max(
    "Maximum value"
    value: Int!
  ) on ARGUMENT_DEFINITION | INPUT_FIELD_DEFINITION

"Validates that the value is at least the specified minimum"
directive @min(
    "Minimum value"
    value: Int!
  ) on ARGUMENT_DEFINITION | INPUT_FIELD_DEFINITION

"Validates that the string is not null, empty, or blank"
directive @notBlank on ARGUMENT_DEFINITION | INPUT_FIELD_DEFINITION

"Indicates an Input Object is a OneOf Input Object."
directive @oneOf on INPUT_OBJECT

"Validates the size of a string"
directive @size(
    "Maximum size"
    max: Int!,
    "Minimum size"
    min: Int!
  ) on ARGUMENT_DEFINITION | INPUT_FIELD_DEFINITION

"Directs the executor to skip this field or fragment when the `if` argument is true."
directive @skip(
    "Skipped when true."
    if: Boolean!
  ) on FIELD | FRAGMENT_SPREAD | INLINE_FRAGMENT

"Marks an operation as potentially slow, as it may interact with third-party systems. Clients are recommended to invoke such operations separately from other queries, with longer timeouts and appropriate long-running operation handling (e.g. loading indicators)."
directive @slowOperation on FIELD_DEFINITION

"Exposes a URL that specifies the behaviour of this scalar."
directive @specifiedBy(
    "The URL that specifies the behaviour of this scalar."
    url: String!
  ) on SCALAR

"Additional error extensions for the ACCOUNT_LOCKED business error."
type AccountLockedErrorExtensions {
  "The remaining lock duration in seconds."
  lockExpiresInSec: Int!
}

"A paginated connection of categories following the GraphQL Cursor Connections Specification."
type CategoriesConnection {
  "The list of edges in the current page."
  edges: [CategoryEdge!]!
  "Pagination information about the current page."
  pageInfo: PageInfo!
  "The total number of items in the connection across all pages."
  totalCount: Int!
}

"Category of incomes or expenses."
type Category {
  "Description of the category."
  description: String
  "Whether this category is used for expenses."
  expense: Boolean!
  "ID of the category."
  id: Long!
  "Whether this category is used for incomes."
  income: Boolean!
  "Name of the category."
  name: String!
}

"An edge in a categories connection."
type CategoryEdge {
  "The cursor of this edge, which can be used for pagination."
  cursor: String!
  "The category at the end of this edge."
  node: Category!
}

"Response for the changePassword mutation. Always succeeds if no error is returned by standard GraphQL error response structure."
type ChangePasswordResponse {
  success: Boolean!
}

"Response for the completeOAuth2Flow mutation."
type CompleteOAuth2FlowResponse {
  "An error reference ID that can be used to identify the specific failure in the logs. Present only when the flow failed."
  errorId: String
  "Whether the OAuth2 authorization flow was completed successfully."
  success: Boolean!
}

"Response for the createAccessTokenByCredentials mutation."
type CreateAccessTokenByCredentialsResponse {
  "The JWT access token for the authenticated user."
  accessToken: String!
}

"Response for the createAccessTokenByWorkspaceAccessToken mutation."
type CreateAccessTokenByWorkspaceAccessTokenResponse {
  "The JWT access token for the authenticated user."
  accessToken: String!
  "The workspace that the access token grants access to."
  workspace: Workspace!
}

"A customer in a workspace."
type Customer {
  "ID of the customer."
  id: Long!
  "Name of the customer."
  name: String!
}

"An edge in a customers connection."
type CustomerEdge {
  "The cursor of this edge, which can be used for pagination."
  cursor: String!
  "The customer at the end of this edge."
  node: Customer!
}

"A paginated connection of customers following the GraphQL Cursor Connections Specification."
type CustomersConnection {
  "The list of edges in the current page."
  edges: [CustomerEdge!]!
  "Pagination information about the current page."
  pageInfo: PageInfo!
  "The total number of items in the connection across all pages."
  totalCount: Int!
}

"A document in a workspace."
type Document {
  "ID of the document."
  id: Long!
  "MIME type of the document."
  mimeType: String!
  "Name of the document."
  name: String!
  "Size of the document in bytes."
  sizeInBytes: Long
  "ID of the storage where the document is stored."
  storageId: String!
  "Time when the document was uploaded, as ISO 8601 timestamp."
  timeUploaded: DateTime!
  "Entities that use this document."
  usedBy: [DocumentUsage!]!
  "Version of the document for optimistic locking."
  version: Int!
}

"An edge in a documents connection."
type DocumentEdge {
  "The cursor of this edge, which can be used for pagination."
  cursor: String!
  "The document at the end of this edge."
  node: Document!
}

"Describes usage of a document by another entity."
type DocumentUsage {
  "Display name of the entity using the document."
  displayName: String!
  "ID of the entity using the document."
  relatedEntityId: Long!
  "Type of entity using the document."
  type: DocumentUsageType!
}

"A paginated connection of documents following the GraphQL Cursor Connections Specification."
type DocumentsConnection {
  "The list of edges in the current page."
  edges: [DocumentEdge!]!
  "Pagination information about the current page."
  pageInfo: PageInfo!
  "The total number of items in the connection across all pages."
  totalCount: Int!
}

"Statistics about document storage usage."
type DocumentsStorageStatisticsItem {
  "The total number of documents stored in this storage across all workspaces of the current user."
  documentsCount: Int!
  "The identifier of the document storage."
  storageId: String!
}

"Documents storage status for the current user."
type DocumentsStorageStatusResponse {
  "Whether the documents storage is active and available."
  active: Boolean!
}

"A document storage available for downloading documents."
type DownloadDocumentStorageResponse {
  "The identifier of the document storage."
  id: String!
}

"Business expense."
type Expense {
  "Documents attached to this expense."
  attachments: [Document!]!
  "Category of the expense."
  category: Category
  "Amounts converted to the default currency."
  convertedAmounts: ExpenseAmounts!
  "Time when the expense was created, as ISO 8601 timestamp."
  createdAt: DateTime!
  "Currency of the expense."
  currency: String!
  "Date when the expense was paid."
  datePaid: LocalDate!
  "Amount of the general tax in cents."
  generalTaxAmount: Long
  "ID of the general tax applied to this expense."
  generalTaxId: Long
  "Rate of the general tax in basis points."
  generalTaxRateInBps: Int
  "ID of the expense."
  id: Long!
  "Amounts for income tax purposes in the default currency."
  incomeTaxableAmounts: ExpenseAmounts!
  "Optional notes for the expense."
  notes: String
  "Original amount of the expense in original currency, in cents."
  originalAmount: Long!
  "Percentage of the expense on business."
  percentOnBusiness: Int!
  "Status of the expense."
  status: ExpenseStatus!
  "Title of the expense."
  title: String!
  "Whether different exchange rate is used for income tax purposes."
  useDifferentExchangeRateForIncomeTaxPurposes: Boolean!
  "Version of the expense for optimistic locking."
  version: Int!
}

"Amounts for an expense in the default currency."
type ExpenseAmounts {
  "Adjusted amount in the default currency."
  adjustedAmountInDefaultCurrency: Long
  "Original amount in the default currency, before adjustments."
  originalAmountInDefaultCurrency: Long
}

"An edge in a expenses connection."
type ExpenseEdge {
  "The cursor of this edge, which can be used for pagination."
  cursor: String!
  "The expense at the end of this edge."
  node: Expense!
}

"A paginated connection of expenses following the GraphQL Cursor Connections Specification."
type ExpensesConnection {
  "The list of edges in the current page."
  edges: [ExpenseEdge!]!
  "Pagination information about the current page."
  pageInfo: PageInfo!
  "The total number of items in the connection across all pages."
  totalCount: Int!
}

"Summary of expenses for a date range."
type ExpensesSummary {
  "Total currency exchange difference for finalized expenses in the range."
  currencyExchangeDifference: Long!
  "Number of finalized expenses in the range."
  finalizedCount: Long!
  "Per-category breakdown of expenses."
  items: [ExpensesSummaryItem!]!
  "Number of pending expenses in the range."
  pendingCount: Long!
  "Total amount of all finalized expenses in the range."
  totalAmount: Long!
}

"Expenses summary for a single category."
type ExpensesSummaryItem {
  "Category of the expenses, or null if no category."
  category: Category
  "Currency exchange difference for finalized expenses."
  currencyExchangeDifference: Long!
  "Number of finalized expenses."
  finalizedCount: Long!
  "Number of pending expenses."
  pendingCount: Long!
  "Total amount for this category."
  totalAmount: Long!
}

"Summary of a finalized general tax."
type FinalizedGeneralTaxSummaryItem {
  "Total amount of items contributing to this tax."
  includedItemsAmount: Long!
  "Number of items contributing to this tax."
  includedItemsNumber: Long!
  "The general tax."
  tax: GeneralTax!
  "Total amount of tax collected or paid."
  taxAmount: Long!
}

"General tax applicable to incomes or expenses."
type GeneralTax {
  "Description of the general tax."
  description: String
  "ID of the general tax."
  id: Long!
  "Rate of the general tax in basis points (1/100 of a percent)."
  rateInBps: Int!
  "Title of the general tax."
  title: String!
}

"An edge in a general taxes connection."
type GeneralTaxEdge {
  "The cursor of this edge, which can be used for pagination."
  cursor: String!
  "The general tax at the end of this edge."
  node: GeneralTax!
}

"A paginated connection of general taxes following the GraphQL Cursor Connections Specification."
type GeneralTaxesConnection {
  "The list of edges in the current page."
  edges: [GeneralTaxEdge!]!
  "Pagination information about the current page."
  pageInfo: PageInfo!
  "The total number of items in the connection across all pages."
  totalCount: Int!
}

"Summary of general taxes for a date range."
type GeneralTaxesSummary {
  "Finalized taxes collected on incomes."
  finalizedCollectedTaxes: [FinalizedGeneralTaxSummaryItem!]!
  "Finalized taxes paid on expenses."
  finalizedPaidTaxes: [FinalizedGeneralTaxSummaryItem!]!
  "Pending taxes to be collected on incomes."
  pendingCollectedTaxes: [PendingGeneralTaxSummaryItem!]!
  "Pending taxes to be paid on expenses."
  pendingPaidTaxes: [PendingGeneralTaxSummaryItem!]!
}

"Google Drive storage integration status for the current user."
type GoogleDriveStorageIntegrationStatusResponse {
  "Whether Google Drive authorization is required to use the storage."
  authorizationRequired: Boolean!
  "The URL to authorize access to Google Drive. Present only when authorization is required."
  authorizationUrl: String
  "The ID of the Google Drive folder used for storing documents."
  folderId: String
  "The name of the Google Drive folder used for storing documents."
  folderName: String
}

"Internationalization settings of the user profile."
type I18nSettings {
  "The language of the user profile, e.g. 'en'. Used for translations."
  language: String!
  "The locale of the user profile, e.g. 'en-US'. Used for formatting dates, numbers, etc."
  locale: String!
}

"An income tax payment in a workspace."
type IncomeTaxPayment {
  "Amount of the tax payment in cents."
  amount: Long!
  "Documents attached to this income tax payment."
  attachments: [Document!]!
  "Date when the tax payment was made."
  datePaid: LocalDate!
  "ID of the income tax payment."
  id: Long!
  "Optional notes for the income tax payment."
  notes: String
  "Date used for reporting purposes."
  reportingDate: LocalDate!
  "Title of the income tax payment."
  title: String!
}

"An edge in a income tax payments connection."
type IncomeTaxPaymentEdge {
  "The cursor of this edge, which can be used for pagination."
  cursor: String!
  "The income tax payment at the end of this edge."
  node: IncomeTaxPayment!
}

"A paginated connection of income tax payments following the GraphQL Cursor Connections Specification."
type IncomeTaxPaymentsConnection {
  "The list of edges in the current page."
  edges: [IncomeTaxPaymentEdge!]!
  "Pagination information about the current page."
  pageInfo: PageInfo!
  "The total number of items in the connection across all pages."
  totalCount: Int!
}

"Summary of income tax payments for a date range."
type IncomeTaxPaymentsSummary {
  "Total amount of all income tax payments in the range."
  totalTaxPayments: Long!
}

"Summary of incomes for a date range."
type IncomesSummary {
  "Total currency exchange difference for finalized incomes in the range."
  currencyExchangeDifference: Long!
  "Number of finalized incomes in the range."
  finalizedCount: Long!
  "Per-category breakdown of incomes."
  items: [IncomesSummaryItem!]!
  "Number of pending incomes in the range."
  pendingCount: Long!
  "Total amount of all finalized incomes in the range."
  totalAmount: Long!
}

"Incomes summary for a single category."
type IncomesSummaryItem {
  "Category of the incomes, or null if no category."
  category: Category
  "Currency exchange difference for finalized incomes."
  currencyExchangeDifference: Long!
  "Number of finalized incomes."
  finalizedCount: Long!
  "Number of pending incomes."
  pendingCount: Long!
  "Total amount for this category."
  totalAmount: Long!
}

"Invoice for a customer."
type Invoice {
  "Amount of the invoice in cents."
  amount: Long!
  "Documents attached to this invoice."
  attachments: [Document!]!
  "Time when the invoice was created, as ISO 8601 timestamp."
  createdAt: DateTime!
  "Currency of the invoice."
  currency: String!
  "Customer of the invoice."
  customer: Customer
  "Date when the invoice was issued."
  dateIssued: LocalDate!
  "Date when the invoice was paid."
  datePaid: LocalDate
  "Date when the invoice was sent."
  dateSent: LocalDate
  "Due date of the invoice."
  dueDate: LocalDate!
  "General tax applied to this invoice."
  generalTax: GeneralTax
  "ID of the invoice."
  id: Long!
  "Optional notes for the invoice."
  notes: String
  "Status of the invoice."
  status: InvoiceStatus!
  "Time when the invoice was cancelled, as ISO 8601 timestamp."
  timeCancelled: DateTime
  "Title of the invoice."
  title: String!
  "Version of the invoice for optimistic locking."
  version: Int!
}

"An edge in a invoices connection."
type InvoiceEdge {
  "The cursor of this edge, which can be used for pagination."
  cursor: String!
  "The invoice at the end of this edge."
  node: Invoice!
}

"A paginated connection of invoices following the GraphQL Cursor Connections Specification."
type InvoicesConnection {
  "The list of edges in the current page."
  edges: [InvoiceEdge!]!
  "Pagination information about the current page."
  pageInfo: PageInfo!
  "The total number of items in the connection across all pages."
  totalCount: Int!
}

type Mutation {
  "Changes the password of the current user."
  changePassword(
    "The current password of the user."
    currentPassword: String! @notBlank @size(max : 100, min : 0),
    "The new password to set for the user."
    newPassword: String! @notBlank @size(max : 100, min : 0)
  ): ChangePasswordResponse! @auth(type : AUTHENTICATED_USER) @businessError(errorCode : "CURRENT_PASSWORD_MISMATCH", errorCodeDescription : "The provided current password does not match the user's actual password.")
  "Completes the OAuth2 authorization flow by processing the authorization server callback."
  completeOAuth2Flow(
    "The authorization code returned by the authorization server."
    code: String,
    "The error code returned by the authorization server if authorization failed."
    error: String,
    "The state token that was included in the authorization request."
    state: String!
  ): CompleteOAuth2FlowResponse! @auth(type : AUTHENTICATED_USER)
  "Authenticates a user by username and password credentials and returns an access token. Optionally issues a refresh token cookie for persistent sessions."
  createAccessTokenByCredentials(
    "Whether to issue a refresh token cookie for persistent sessions. Defaults to false if not provided."
    issueRefreshTokenCookie: Boolean,
    "The password of the user."
    password: String! @notBlank,
    "The username of the user."
    userName: String! @notBlank
  ): CreateAccessTokenByCredentialsResponse! @auth(type : ANONYMOUS) @businessError(errorCode : "BAD_CREDENTIALS", errorCodeDescription : "The provided credentials are invalid.") @businessError(errorCode : "USER_NOT_ACTIVATED", errorCodeDescription : "The user account has not been activated yet.") @businessError(errorCode : "ACCOUNT_LOCKED", errorCodeDescription : "The account is temporarily locked due to too many failed login attempts. The error extensions will include 'lockExpiresInSec' with the remaining lock duration in seconds.") @businessError(errorCode : "LOGIN_NOT_AVAILABLE", errorCodeDescription : "Login is temporarily unavailable due to too many concurrent authentication requests for this user.")
  "Authenticates a user by a shared workspace access token and returns an access token. This is used for login-by-link functionality."
  createAccessTokenByWorkspaceAccessToken(
    "The shared workspace access token."
    workspaceAccessToken: String! @notBlank
  ): CreateAccessTokenByWorkspaceAccessTokenResponse! @auth(type : ANONYMOUS) @businessError(errorCode : "INVALID_WORKSPACE_ACCESS_TOKEN", errorCodeDescription : "The provided workspace access token is not valid (unknown, expired, or revoked).")
  "Creates a new category in the specified workspace."
  createCategory(
    "Description of the category."
    description: String @size(max : 1000, min : 0),
    "Whether this category is used for expenses."
    expense: Boolean!,
    "Whether this category is used for incomes."
    income: Boolean!,
    "Name of the category."
    name: String! @notBlank @size(max : 255, min : 0),
    "ID of the workspace to create the category in."
    workspaceId: Long!
  ): Category! @auth(type : REGULAR_USER)
  "Creates a new customer in the specified workspace."
  createCustomer(
    "Name of the customer."
    name: String! @notBlank @size(max : 255, min : 0),
    "ID of the workspace to create the customer in."
    workspaceId: Long!
  ): Customer! @auth(type : REGULAR_USER)
  "Creates a new expense in the specified workspace."
  createExpense(
    "IDs of documents attached to this expense."
    attachments: [Long!],
    "ID of the category for this expense."
    categoryId: Long,
    "Converted amount in the default currency, in cents. Null if not yet converted."
    convertedAmountInDefaultCurrency: Long,
    "Currency of the expense."
    currency: String! @notBlank,
    "Date when the expense was paid."
    datePaid: LocalDate!,
    "ID of the general tax applied to this expense."
    generalTaxId: Long,
    "Amount for income tax purposes in the default currency, in cents. Null if not yet converted."
    incomeTaxableAmountInDefaultCurrency: Long,
    "Optional notes for the expense."
    notes: String @size(max : 1024, min : 0),
    "Original amount of the expense in original currency, in cents."
    originalAmount: Long!,
    "Percentage of the expense on business. Defaults to 100."
    percentOnBusiness: Int @max(value : 100) @min(value : 1),
    "Title of the expense."
    title: String! @notBlank @size(max : 255, min : 0),
    "Whether different exchange rate is used for income tax purposes."
    useDifferentExchangeRateForIncomeTaxPurposes: Boolean!,
    "ID of the workspace to create the expense in."
    workspaceId: Long!
  ): Expense! @auth(type : REGULAR_USER)
  "Creates a new general tax in the specified workspace."
  createGeneralTax(
    "Description of the general tax."
    description: String @size(max : 255, min : 0),
    "Rate of the general tax in basis points (1/100 of a percent)."
    rateInBps: Int! @max(value : 10000) @min(value : 0),
    "Title of the general tax."
    title: String! @notBlank @size(max : 255, min : 0),
    "ID of the workspace to create the general tax in."
    workspaceId: Long!
  ): GeneralTax! @auth(type : REGULAR_USER)
  "Creates a new income tax payment in the specified workspace."
  createIncomeTaxPayment(
    "Amount of the tax payment in cents."
    amount: Long! @min(value : 1),
    "IDs of documents attached to this income tax payment."
    attachments: [Long!],
    "Date when the tax payment was made."
    datePaid: LocalDate!,
    "Optional notes for the income tax payment."
    notes: String @size(max : 1024, min : 0),
    "Date used for reporting purposes. Defaults to datePaid if not specified."
    reportingDate: LocalDate,
    "Title of the income tax payment."
    title: String! @notBlank @size(max : 255, min : 0),
    "ID of the workspace to create the income tax payment in."
    workspaceId: Long!
  ): IncomeTaxPayment! @auth(type : REGULAR_USER)
  "Creates a new invoice in the specified workspace."
  createInvoice(
    "Amount of the invoice in cents."
    amount: Long!,
    "IDs of documents attached to this invoice."
    attachments: [Long!],
    "Currency of the invoice."
    currency: String! @notBlank,
    "ID of the customer for this invoice."
    customerId: Long!,
    "Date when the invoice was issued."
    dateIssued: LocalDate!,
    "Date when the invoice was paid."
    datePaid: LocalDate,
    "Date when the invoice was sent."
    dateSent: LocalDate,
    "Due date of the invoice."
    dueDate: LocalDate!,
    "ID of the general tax applied to this invoice."
    generalTaxId: Long,
    "Optional notes for the invoice."
    notes: String @size(max : 1024, min : 0),
    "Title of the invoice."
    title: String! @notBlank @size(max : 255, min : 0),
    "ID of the workspace to create the invoice in."
    workspaceId: Long!
  ): Invoice! @auth(type : REGULAR_USER)
  "Creates a new workspace for the current user."
  createWorkspace(
    "Default currency code of the workspace (ISO 4217, 3 characters)."
    defaultCurrency: String! @notBlank @size(max : 3, min : 0),
    "Name of the workspace."
    name: String! @notBlank @size(max : 255, min : 0)
  ): Workspace! @auth(type : REGULAR_USER)
  "Creates a new access token for sharing workspace access."
  createWorkspaceAccessToken(
    "The expiration time of the token."
    validTill: DateTime!,
    "ID of the workspace to create the token for."
    workspaceId: Long!
  ): WorkspaceAccessToken! @auth(type : REGULAR_USER)
  "Updates an existing category in the specified workspace."
  editCategory(
    "New description of the category."
    description: String @size(max : 1000, min : 0),
    "Whether this category is used for expenses."
    expense: Boolean!,
    "ID of the category to update."
    id: Long!,
    "Whether this category is used for incomes."
    income: Boolean!,
    "New name of the category."
    name: String! @notBlank @size(max : 255, min : 0),
    "ID of the workspace the category belongs to."
    workspaceId: Long!
  ): Category! @auth(type : REGULAR_USER)
  "Updates an existing customer in the specified workspace."
  editCustomer(
    "ID of the customer to update."
    id: Long!,
    "New name of the customer."
    name: String! @notBlank @size(max : 255, min : 0),
    "ID of the workspace the customer belongs to."
    workspaceId: Long!
  ): Customer! @auth(type : REGULAR_USER)
  "Updates an existing expense in the specified workspace."
  editExpense(
    "New IDs of documents attached to this expense."
    attachments: [Long!],
    "New ID of the category for this expense."
    categoryId: Long,
    "New converted amount in the default currency, in cents. Null if not yet converted."
    convertedAmountInDefaultCurrency: Long,
    "New currency of the expense."
    currency: String! @notBlank,
    "New date when the expense was paid."
    datePaid: LocalDate!,
    "New ID of the general tax applied to this expense."
    generalTaxId: Long,
    "ID of the expense to update."
    id: Long!,
    "New amount for income tax purposes in the default currency, in cents. Null if not yet converted."
    incomeTaxableAmountInDefaultCurrency: Long,
    "New optional notes for the expense."
    notes: String @size(max : 1024, min : 0),
    "New original amount of the expense in original currency, in cents."
    originalAmount: Long!,
    "New percentage of the expense on business. Defaults to 100."
    percentOnBusiness: Int @max(value : 100) @min(value : 1),
    "New title of the expense."
    title: String! @notBlank @size(max : 255, min : 0),
    "Whether different exchange rate is used for income tax purposes."
    useDifferentExchangeRateForIncomeTaxPurposes: Boolean!,
    "ID of the workspace the expense belongs to."
    workspaceId: Long!
  ): Expense! @auth(type : REGULAR_USER)
  "Updates an existing general tax in the specified workspace."
  editGeneralTax(
    "New description of the general tax."
    description: String @size(max : 255, min : 0),
    "ID of the general tax to update."
    id: Long!,
    "New rate of the general tax in basis points (1/100 of a percent)."
    rateInBps: Int! @max(value : 10000) @min(value : 0),
    "New title of the general tax."
    title: String! @notBlank @size(max : 255, min : 0),
    "ID of the workspace the general tax belongs to."
    workspaceId: Long!
  ): GeneralTax! @auth(type : REGULAR_USER)
  "Updates an existing income tax payment in the specified workspace."
  editIncomeTaxPayment(
    "New amount of the tax payment in cents."
    amount: Long! @min(value : 1),
    "New IDs of documents attached to this income tax payment."
    attachments: [Long!],
    "New date when the tax payment was made."
    datePaid: LocalDate!,
    "ID of the income tax payment to update."
    id: Long!,
    "New optional notes for the income tax payment."
    notes: String @size(max : 1024, min : 0),
    "New date used for reporting purposes. Defaults to datePaid if not specified."
    reportingDate: LocalDate,
    "New title of the income tax payment."
    title: String! @notBlank @size(max : 255, min : 0),
    "ID of the workspace the income tax payment belongs to."
    workspaceId: Long!
  ): IncomeTaxPayment! @auth(type : REGULAR_USER)
